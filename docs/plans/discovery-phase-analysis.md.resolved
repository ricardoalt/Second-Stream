## 5. Modelo de Datos: Material Intake

### Campos del Material Discovery (reemplaza secciones de Water Project)

```typescript
// Nueva estructura de discovery_data en project_data JSONB
interface DiscoveryData {
  // === IDENTIDAD DEL MATERIAL ===
  materialIdentity: {
    alias: string;               // Nombre interno del cliente ("5850", "B980")
    commonName: string;          // Nombre real ("Used MEK", "Spent Glycol")
    family: string;              // Familia/tipo (solvent, acid, metal, etc.)
    primaryComponent: string;    // Ingrediente principal
    legalStatus: 'waste' | 'product' | 'unknown';
  };
  
  // === PROCESO GENERADOR ===
  generatingProcess: {
    description: string;         // Texto libre del proceso
    industry: string;            // Industria
    equipment: string;           // Línea/equipo
    tags: string[];              // Tags del proceso
  };
  
  // === FORMA Y PACKAGING ===
  packaging: {
    form: string;                // liquid, solid, gas, sludge
    containerType: string;       // drum, tote, tanker, supersack, etc.
    quantity: number;
    quantityUnit: string;        // lbs, gallons, tons, etc.
    density?: number;
    densityUnit?: string;
  };
  
  // === OPERACIONAL ===
  operational: {
    location: string;            // Viene del Location del proyecto
    recurrence: 'one-off' | 'weekly' | 'monthly' | 'quarterly' | 'annual';
    estimatedFrequency?: string;
    deadline?: string;           // ISO date
    urgencyLevel: 'low' | 'medium' | 'high' | 'critical';
    productionCritical: boolean; // ¿Limita producción?
  };
  
  // === PRIORIDADES DEL CLIENTE ===
  clientPriorities: {
    brandProtection: boolean;
    noExport: boolean;
    costPriority: boolean;
    complianceFocus: boolean;
    customPriorities: string[];
  };
  
  // === COSTO ACTUAL ===
  currentCost: {
    declaredCostPerUnit: number;
    declaredUnit: string;        // per lb, per gallon, per drum
    invoiceLineItems: Array<{
      description: string;
      amount: number;
    }>;
    effectiveCostPerUnit?: number; // Calculado
    currentVendor?: string;
  };
  
  // === EVIDENCIA / DOCUMENTOS ===
  evidence: Array<{
    type: 'sds' | 'waste_profile' | 'manifest' | 'bol' | 'lab_analysis' | 'invoice' | 'photo' | 'other';
    fileId?: string;             // Link a ProjectFile
    date?: string;               // Fecha del documento
    freshness: 'fresh' | 'aging' | 'stale' | 'expired';
    confidence: 'high' | 'medium' | 'low';
    notes?: string;
    isVirginSpec: boolean;       // SDS para virgin vs spent
  }>;
  
  // === GAP TRACKING ===
  gaps: Array<{
    field: string;               // Qué campo falta
    responsible: string;         // Quién debe proveerlo
    impact: 'blocks_proposal' | 'blocks_pricing' | 'optional';
    createdAt: string;
    resolvedAt?: string;
    reminderSentAt?: string;
  }>;
}
```

> [!IMPORTANT]
> Este modelo vivirá dentro del JSONB `project_data` existente — **no requiere migraciones de schema SQL**. Se agrega como un nuevo namespace `discovery` dentro del JSON.

