{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["ultracite/next"],
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": [
				"scripts/**",
				"lib/utils/logger.ts",
				"app/global-error.tsx",
				"components/features/proposals/overview/section-error-boundary.tsx",
				"lib/utils/proposal-generation-persistence.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["components/ui/*-skeleton.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": [
				"components/features/proposals/overview/top-resources.tsx",
				"components/shared/common/file-uploader-sections.tsx"
			],
			"linter": {
				"rules": {
					"performance": {
						"noImgElement": "off"
					}
				}
			}
		},
		{
			"includes": [
				"components/ui/circular-gauge.tsx",
				"components/features/admin/org-switcher.tsx",
				"components/shared/common/file-uploader-sections.tsx",
				"components/chat-ui/ui/field.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off"
					}
				}
			}
		},
		{
			"includes": ["hooks/use-theme.tsx"],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"includes": [
				"components/chat-ui/ui/input-group.tsx",
				"components/chat-ui/ui/button-group.tsx",
				"components/ui/input-group.tsx",
				"components/ui/button-group.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		},
		{
			"includes": ["components/chat-ui/ui/field.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noDoubleEquals": "off",
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["components/chat-ui/ui/label.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off"
					}
				}
			}
		},
		{
			"includes": ["components/chat-ui/ui/sidebar.tsx"],
			"linter": {
				"rules": {
					"correctness": {
						"useExhaustiveDependencies": "off"
					}
				}
			}
		},
		{
			"includes": [
				"components/chat-ui/openchat-logo.tsx",
				"components/chat-ui/ai-elements/model-selector.tsx",
				"components/chat-ui/ai-elements/sources.tsx"
			],
			"linter": {
				"rules": {
					"performance": {
						"noImgElement": "off"
					}
				}
			}
		},
		{
			"includes": ["components/chat-ui/ai-elements/shimmer.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
