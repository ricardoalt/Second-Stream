{% extends '_base.html.j2' %}
{% from '_macros.html.j2' import gate_callout, safety_callout, insight_callout %}

{% block title %}SecondStream Analytical Read — {{ payload.customer | e }}{% endblock %}
{% block footer_center %}Internal handover{% endblock %}

{% block head_extra %}
<style>
  /* ── Analytical Read customer-reference layout ── */
  .analytical-read .document-header {
    margin-bottom: 18pt;
    page-break-inside: avoid;
  }

  .analytical-read .header-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 8pt;
  }

  .analytical-read .header-logo-cell {
    width: 124pt;
    padding: 0;
    vertical-align: top;
  }

  .analytical-read .header-logo-cell img {
    width: 112pt;
    height: auto;
  }

  .analytical-read .header-copy-cell {
    padding: 0;
    vertical-align: top;
  }

  .analytical-read .header-title {
    margin: 0 0 2pt 0;
    font-size: 9pt;
    line-height: 1.25;
    font-weight: bold;
    color: var(--ink);
  }

  .analytical-read .header-meta {
    margin: 0;
    font-size: 8pt;
    line-height: 1.25;
    color: var(--ink-muted);
  }

  .analytical-read .cover-rule {
    margin: 7pt 0 12pt 0;
  }

  .analytical-read .doc-title {
    margin: 0 0 4pt 0;
    font-size: 22pt;
    line-height: 1.16;
    font-weight: bold;
    color: var(--brand-primary);
  }

  .analytical-read .doc-subtitle {
    margin: 0 0 2pt 0;
    font-size: 13pt;
    line-height: 1.25;
    font-style: italic;
    color: var(--ink-muted);
  }

  .analytical-read .handover-tag {
    margin: 0;
    font-size: 8pt;
    color: var(--ink-soft);
  }

  .analytical-read .section-h1 {
    font-size: 15pt;
    font-weight: bold;
    color: var(--brand-primary);
    margin: 20pt 0 6pt 0;
    padding-bottom: 0;
    border-bottom: 0;
    page-break-after: avoid;
  }

  .analytical-read .body-text {
    line-height: 1.4;
    margin: 0 0 6pt 0;
  }

  .analytical-read .analytical-table {
    margin: 4pt 0 10pt 0;
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
  }
  .analytical-read .analytical-table thead th {
    padding: 3pt 5pt;
    font-size: 8pt;
  }
  .analytical-read .analytical-table tbody td {
    padding: 3pt 5pt;
    font-size: 8pt;
  }

  .analytical-read .callout-gate,
  .analytical-read .callout-safety {
    border: 0.75pt solid var(--gate-amber);
    border-left: 3pt solid var(--gate-amber);
    margin: 6pt 0;
    padding: 7pt 10pt;
  }

  .analytical-read .callout-gate-closed {
    border-color: var(--gate-closed);
    border-left-color: var(--gate-closed);
  }

  .analytical-read .callout-safety-red {
    border-color: var(--safety-red);
    border-left-color: var(--safety-red);
  }

  .analytical-read .callout-safety-yellow {
    border-color: var(--safety-yellow);
    border-left-color: var(--safety-yellow);
  }

  .analytical-read .insight-callout {
    margin: 16pt 0;
    padding: 10pt 14pt;
    background: #EAF2FB;
  }
  .analytical-read .insight-callout p {
    font-size: 11pt;
    text-align: center;
    font-style: italic;
    font-weight: bold;
    color: var(--brand-primary);
    margin: 0;
  }

  .analytical-read .section-lead {
    margin: 0 0 6pt 0;
    font-size: 9.5pt;
    font-weight: bold;
    color: var(--ink);
  }

  .analytical-read .evidence-item,
  .analytical-read .gap-item,
  .analytical-read .narrative-item {
    margin: 0 0 6pt 0;
    font-size: 9pt;
    line-height: 1.4;
    color: var(--ink);
  }

  .analytical-read .evidence-tag,
  .analytical-read .gap-label {
    font-weight: bold;
    color: var(--brand-primary);
  }

  .analytical-read .confidence {
    font-weight: bold;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .analytical-read .gap-group-title {
    margin: 7pt 0 3pt 0;
    font-size: 9pt;
    font-weight: bold;
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .analytical-read .narrative-bullets {
    margin: 2pt 0 0 0;
    padding-left: 13pt;
    font-size: 8.5pt;
    color: var(--ink-muted);
  }
</style>
{% endblock %}

{% block body %}

<div class="analytical-read">

<div class="document-header">
  <table class="header-table">
    <tr>
      <td class="header-logo-cell">
        <img src="assets/secondstream_logo.svg" alt="SecondStream">
      </td>
      <td class="header-copy-cell">
        <p class="header-title">{{ payload.customer }}</p>
        <p class="header-meta">Sites: {{ payload.stream }}&nbsp;&nbsp;|&nbsp;&nbsp;{{ payload.date }}</p>
      </td>
    </tr>
  </table>
  <hr class="cover-rule">
  <h1 class="doc-title">Analytical Read</h1>
  <p class="doc-subtitle">The evidenced case behind the ideation</p>
  <p class="handover-tag">Discovery Analytical Read · SecondStream Discovery Agent v3.1</p>
</div>

{% if payload.gate_status %}
{{ gate_callout(payload.gate_status, payload.gate_blockers | join(' ') if payload.gate_blockers else payload.executive_summary) }}
{% endif %}

{% if payload.safety_callouts %}
<div style="margin-bottom:14pt;">
  {% for flag in payload.safety_callouts %}
  {% set safety_message = (flag.sub_stream ~ ": " ~ flag.description ~ (" — " ~ flag.intervention if flag.intervention else ""))
      | replace('H&lt;sub&gt;2&lt;/sub&gt;S', 'H₂S')
      | replace('H&amp;lt;sub&amp;gt;2&amp;lt;/sub&amp;gt;S', 'H₂S') %}
  {{ safety_callout(
      flag.severity,
      safety_message
  ) }}
  {% endfor %}
</div>
{% endif %}

{% if not payload.tables %}
<div class="avoid-break" style="margin-bottom:12pt;">
  <h2 class="section-h1">Executive Summary</h2>
  <p class="body-text">{{ payload.executive_summary }}</p>
</div>
{% endif %}

{% for table in payload.tables %}
<div class="avoid-break" style="margin-bottom:14pt;">
  <h2 class="section-h1">{{ table.title }}</h2>
  <table class="analytical-table">
    <thead>
      <tr>
        {% for header in table.headers %}<th>{{ header }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in table.rows %}
      <tr>
        {% for cell in row %}<td>{{ cell }}</td>{% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% if loop.index == 1 and payload.evidence_tags %}
<div class="avoid-break" style="margin-bottom:14pt;">
  {% for ev in payload.evidence_tags %}
  <p class="evidence-item"><span class="evidence-tag">[{{ ev.tag }}] {{ ev.title }}:</span> {{ ev.description }}{% if ev.confidence %} <span class="confidence">Confidence: {{ ev.confidence }}</span>{% endif %}</p>
  {% endfor %}
</div>
{% endif %}
{% endfor %}

{% if not payload.tables and payload.evidence_tags %}
<div class="avoid-break" style="margin-bottom:14pt;">
  {% for ev in payload.evidence_tags %}
  <p class="evidence-item"><span class="evidence-tag">[{{ ev.tag }}] {{ ev.title }}:</span> {{ ev.description }}{% if ev.confidence %} <span class="confidence">Confidence: {{ ev.confidence }}</span>{% endif %}</p>
  {% endfor %}
</div>
{% endif %}

{% for section in payload.narrative_sections %}
<div class="avoid-break" style="margin-bottom:14pt;">
  <h2 class="section-h1">{{ section.title }}</h2>
  {% if section.body %}<p class="narrative-item">{{ section.body }}</p>{% endif %}
  {% if section.bullets %}
  <ul class="narrative-bullets">{% for item in section.bullets %}<li>{{ item }}</li>{% endfor %}</ul>
  {% endif %}
</div>
{% endfor %}

{% if payload.gap_sections %}
<div class="avoid-break" style="margin-bottom:14pt;">
  <h2 class="section-h1">Required gaps and regulatory flags for Assessment</h2>
  {% for section in payload.gap_sections %}
  <p class="gap-group-title">{{ section.title }}</p>
  {% for gap in section.items %}<p class="gap-item"><span class="gap-label">{{ gap.label }}:</span> {{ gap.detail }}</p>{% endfor %}
  {% endfor %}
</div>
{% endif %}

{{ insight_callout(payload.strategic_insight) }}

</div>

{% endblock %}
