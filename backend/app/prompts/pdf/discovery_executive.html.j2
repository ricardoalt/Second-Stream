{% extends '_base.html.j2' %}
{% from '_macros.html.j2' import cover_block, safety_callout, insight_callout %}

{% block title %}SecondStream Executive Discovery Report — {{ payload.customer | e }}{% endblock %}
{% block footer_center %}Executive Discovery Report — Confidential{% endblock %}

{% block body %}

{{ cover_block(
    customer=payload.customer,
    stream=payload.stream,
    date=payload.snapshot[:10] if payload.snapshot else "",
    doc_type="Executive Discovery Report",
    gate=payload.gate_status,
    gate_blocker=payload.gate_blocker
) }}

<!-- Snapshot -->
<div class="avoid-break" style="margin-bottom:16pt;">
  <h2 class="section-h1">Snapshot</h2>
  <p class="body-text">{{ payload.snapshot }}</p>
</div>

<!-- Safety Flags -->
{% if payload.safety_callouts %}
<div style="margin-bottom:20pt;">
  <h2 class="section-h1">Safety Flags</h2>
  {% for flag in payload.safety_callouts %}
  {{ safety_callout(
      flag.severity,
      flag.sub_stream ~ ": " ~ flag.description ~ (" — " ~ flag.intervention if flag.intervention else "")
  ) }}
  {% endfor %}
</div>
{% else %}
<div class="callout-safety callout-safety-none avoid-break" style="margin-bottom:20pt;">
  <p style="font-style:italic;color:#4A5260;margin:0;">No safety flags raised.</p>
</div>
{% endif %}

<!-- Eight sections -->
{% for section in payload.sections %}
<div class="avoid-break" style="margin-bottom:18pt;">
  <h2 class="section-h1">{{ loop.index }}. {{ section.title }}</h2>
  <p class="body-lead">{{ section.lead }}</p>
  <p class="body-text">{{ section.body }}</p>
  {% if section.close %}<p class="body-close">{{ section.close }}</p>{% endif %}
</div>
{% endfor %}

<!-- Strategic insight -->
{{ insight_callout(payload.strategic_insight) }}

<!-- What to ask next -->
<div style="margin-bottom:20pt;">
  <h2 class="section-h1">What to ask next</h2>
  <div class="killer-question-box">
    <p class="kq-label">Killer Question</p>
    <p class="kq-text">{{ payload.killer_question.question }}</p>
    <p class="kq-why">Why it matters: {{ payload.killer_question.why_it_matters }}</p>
  </div>
  {% if payload.follow_up_questions %}
  <h3 class="section-h2">If the conversation opens up</h3>
  {% for q in payload.follow_up_questions %}
  <div class="followup-item">
    <p class="fq-q">{{ q.question }}</p>
    <p class="fq-why">Why it matters: {{ q.why_it_matters }}</p>
  </div>
  {% endfor %}
  {% endif %}
</div>

{% endblock %}
