{% extends '_base.html.j2' %}
{% from '_macros.html.j2' import cover_block, page_band_line_2, theme_header, why_it_matters_box %}

{% block title %}SecondStream Discovery Playbook — {{ payload.customer | e }}{% endblock %}
{% block footer_left %}SecondStream · Discovery Agent v3{% endblock %}
{% block footer_center %}Internal handover · Discovery{% endblock %}

{% block head_extra %}
<style>
  /* ── Call Playbook overrides — cover styles come from design/base.css ── */
  .call-playbook .opening-note {
    margin: 0 0 14pt 0;
    font-size: 9.5pt;
    line-height: 1.35;
    font-weight: bold;
    color: var(--ink);
  }

  .call-playbook .theme-block {
    margin-bottom: 16pt;
  }

  .call-playbook .theme-header {
    margin: 0 0 4pt 0;
    padding: 5pt 10pt;
    background: var(--brand-primary);
  }

  .call-playbook .theme-num {
    width: 34pt;
    font-size: 16pt;
    line-height: 1;
    color: #FFFFFF;
  }

  .call-playbook .theme-title {
    font-size: 14pt;
    line-height: 1.2;
    color: #FFFFFF;
  }

  .call-playbook .theme-context {
    margin: 0 0 6pt 0;
    font-size: 8.5pt;
    line-height: 1.35;
    font-style: italic;
    color: var(--ink-muted);
  }

  .call-playbook .probe-list {
    margin: 0 0 7pt 0;
    padding-left: 13pt;
  }

  .call-playbook .probe-list li {
    margin-bottom: 3pt;
    font-size: 9.5pt;
    line-height: 1.35;
    color: var(--ink);
  }

  .call-playbook .killer-question-box {
    margin-top: 7pt;
  }

  .call-playbook .killer-question-box + .killer-question-box {
    margin-top: 5pt;
  }

  .call-playbook .why-it-matters {
    margin: 7pt 0 0 0;
    padding: 7pt 10pt 7pt 12pt;
    border: 0.75pt solid var(--brand-secondary);
    border-left: 3pt solid var(--brand-secondary);
    background: var(--paper-tint);
  }

  .call-playbook .why-it-matters .wim-label {
    margin-bottom: 4pt;
    font-size: 9.5pt;
    color: var(--brand-primary);
  }

  .call-playbook .why-it-matters ul {
    padding-left: 13pt;
  }

  .call-playbook .why-it-matters li {
    margin-bottom: 2pt;
    font-size: 9pt;
    line-height: 1.35;
  }
</style>
{% endblock %}

{% block body %}

<div class="call-playbook">

{{ cover_block(
    title="Call Playbook",
    subtitle="Open during the producer call. Flip to any theme.",
    header_line_1=payload.header_line,
    header_line_2=page_band_line_2("Discovery Call Playbook"),
    evidence_caption=payload.evidence_caption,
) }}

{% if payload.orientation_note %}
<div class="avoid-break">
  <p class="opening-note">{{ payload.orientation_note }}</p>
</div>
{% endif %}

{% if payload.opening_context %}
<p class="theme-context">{{ payload.opening_context }}</p>
{% endif %}

{% for theme in payload.themes %}
<div class="theme-block avoid-break">
  {{ theme_header(theme.number, theme.title) }}
  <p class="theme-context">{{ theme.body }}</p>

  {% if theme.probe_questions %}
  <ul class="probe-list">
    {% for q in theme.probe_questions %}
    <li>{{ q }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if theme.why_it_matters %}
  {{ why_it_matters_box(theme.why_it_matters) }}
  {% endif %}

  {% if theme.number == 11 and theme.probe_questions %}
    {% for question in theme.probe_questions %}
    <div class="killer-question-box">
      <p class="kq-label">Smart question</p>
      <p class="kq-text">{{ question }}</p>
    </div>
    {% endfor %}
  {% endif %}
</div>
{% endfor %}

</div>

{% endblock %}
